<idea-plugin>
    <id>com.somniacs.beconductor</id>
    <name>be-conductor</name>
    <version>0.2.0</version>
    <vendor url="https://github.com/somniacs/be-conductor">Somniacs</vendor>

    <description><![CDATA[
        Orchestrate AI coding agent sessions (Claude, Codex, Gemini, Aider, and more)
        via <a href="https://github.com/somniacs/be-conductor">be-conductor</a>.
        Create sessions with git worktree isolation, manage running sessions,
        view diffs, merge changes — all from within the IDE.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Tool window (right sidebar) -->
        <toolWindow id="be-conductor" anchor="right"
                    icon="/icons/be-conductor.svg"
                    factoryClass="com.somniacs.beconductor.toolwindow.BeConductorToolWindowFactory"/>

        <!-- API client singleton -->
        <applicationService
            serviceImplementation="com.somniacs.beconductor.api.BeConductorClient"/>

        <!-- Notification group -->
        <notificationGroup id="be-conductor" displayType="BALLOON"/>
    </extensions>

    <actions>
        <!-- Toolbar group -->
        <group id="BeConductor.ToolbarGroup" text="be-conductor" popup="true"
               icon="/icons/be-conductor.svg">
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
            <add-to-group group-id="MainToolBar" anchor="last"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </group>

        <action
            id="BeConductor.RunSession"
            class="com.somniacs.beconductor.RunSessionAction"
            text="New Session"
            description="Start a new AI agent session via be-conductor"
            icon="/icons/be-conductor.svg">
            <add-to-group group-id="BeConductor.ToolbarGroup" anchor="first"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action
            id="BeConductor.OpenDashboard"
            class="com.somniacs.beconductor.OpenDashboardAction"
            text="Open Dashboard"
            description="Open the be-conductor web dashboard in a browser"
            icon="AllIcons.General.Web">
            <add-to-group group-id="BeConductor.ToolbarGroup" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
