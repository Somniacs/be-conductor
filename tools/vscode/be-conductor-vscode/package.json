{
  "name": "be-conductor-launcher",
  "displayName": "be-conductor",
  "description": "Launch AI agent sessions from VS Code via be-conductor (https://github.com/somniacs/be-conductor)",
  "version": "0.3.53",
  "publisher": "somniacs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/somniacs/be-conductor"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "be-conductor.launch",
        "title": "be-conductor: New Session",
        "icon": {
          "light": "icons/be-conductor-light.svg",
          "dark": "icons/be-conductor-dark.svg"
        }
      },
      {
        "command": "be-conductor.openDashboard",
        "title": "be-conductor: Open Dashboard",
        "icon": "$(globe)"
      },
      {
        "command": "be-conductor.refresh",
        "title": "be-conductor: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "be-conductor.attachSession",
        "title": "Attach Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "be-conductor.resumeSession",
        "title": "Resume Session",
        "icon": "$(debug-start)"
      },
      {
        "command": "be-conductor.stopSession",
        "title": "Stop Session",
        "icon": "$(debug-stop)"
      },
      {
        "command": "be-conductor.killSession",
        "title": "Kill Session",
        "icon": "$(close)"
      },
      {
        "command": "be-conductor.forgetSession",
        "title": "Forget Session",
        "icon": "$(trash)"
      },
      {
        "command": "be-conductor.dismissSession",
        "title": "Dismiss Session",
        "icon": "$(trash)"
      },
      {
        "command": "be-conductor.cloneSession",
        "title": "Clone Session",
        "icon": "$(copy)"
      },
      {
        "command": "be-conductor.finalizeWorktree",
        "title": "Finalize Worktree",
        "icon": "$(check)"
      },
      {
        "command": "be-conductor.viewDiff",
        "title": "View Worktree Diff",
        "icon": "$(diff)"
      },
      {
        "command": "be-conductor.mergeWorktree",
        "title": "Merge Worktree",
        "icon": "$(git-merge)"
      },
      {
        "command": "be-conductor.deleteWorktree",
        "title": "Delete Worktree",
        "icon": "$(trash)"
      },
      {
        "command": "be-conductor.gcWorktrees",
        "title": "Garbage Collect Stale Worktrees",
        "icon": "$(clear-all)"
      },
      {
        "command": "be-conductor.addServer",
        "title": "be-conductor: Add Server",
        "icon": "$(add)"
      },
      {
        "command": "be-conductor.removeServer",
        "title": "Remove Server",
        "icon": "$(trash)"
      },
      {
        "command": "be-conductor.toggleServer",
        "title": "Enable/Disable Server"
      },
      {
        "command": "be-conductor.renameServer",
        "title": "Rename Server"
      },
      {
        "command": "be-conductor.probeServer",
        "title": "Test Connection"
      },
      {
        "command": "be-conductor.scanTailscale",
        "title": "be-conductor: Scan Tailscale",
        "icon": "$(search)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "be-conductor",
          "title": "be-conductor",
          "icon": "icons/be-conductor.svg"
        }
      ]
    },
    "views": {
      "be-conductor": [
        {
          "id": "be-conductor.sessions",
          "name": "Sessions"
        },
        {
          "id": "be-conductor.worktrees",
          "name": "Worktrees"
        },
        {
          "id": "be-conductor.servers",
          "name": "Servers"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "be-conductor.launch",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "be-conductor.launch",
          "when": "view == be-conductor.sessions",
          "group": "navigation@1"
        },
        {
          "command": "be-conductor.openDashboard",
          "when": "view == be-conductor.sessions",
          "group": "navigation@2"
        },
        {
          "command": "be-conductor.refresh",
          "when": "view == be-conductor.sessions || view == be-conductor.worktrees",
          "group": "navigation@3"
        },
        {
          "command": "be-conductor.gcWorktrees",
          "when": "view == be-conductor.worktrees",
          "group": "navigation@4"
        },
        {
          "command": "be-conductor.addServer",
          "when": "view == be-conductor.servers",
          "group": "navigation@1"
        },
        {
          "command": "be-conductor.scanTailscale",
          "when": "view == be-conductor.servers",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "be-conductor.attachSession",
          "when": "viewItem =~ /^session-running(-agent(-other)?)?$/",
          "group": "inline@1"
        },
        {
          "command": "be-conductor.stopSession",
          "when": "viewItem =~ /^session-(running|running-attached|running-agent|running-attached-agent|running-agent-other|running-attached-agent-other|stopping)$/",
          "group": "inline@2"
        },
        {
          "command": "be-conductor.killSession",
          "when": "viewItem =~ /^session-(running|running-attached|running-agent|running-attached-agent|running-agent-other|running-attached-agent-other|stopping)$/",
          "group": "session@1"
        },
        {
          "command": "be-conductor.forgetSession",
          "when": "viewItem =~ /^session-(running|running-attached|running-agent|running-attached-agent|running-agent-other|running-attached-agent-other|stopping)$/",
          "group": "session@2"
        },
        {
          "command": "be-conductor.cloneSession",
          "when": "viewItem =~ /^session-(running|running-attached|running-agent|running-attached-agent)$/",
          "group": "session@3"
        },
        {
          "command": "be-conductor.resumeSession",
          "when": "viewItem == session-resumable",
          "group": "inline@1"
        },
        {
          "command": "be-conductor.dismissSession",
          "when": "viewItem =~ /^session-(exited|resumable)$/",
          "group": "inline@2"
        },
        {
          "command": "be-conductor.finalizeWorktree",
          "when": "viewItem == worktree-active",
          "group": "inline@1"
        },
        {
          "command": "be-conductor.viewDiff",
          "when": "viewItem =~ /^worktree-/",
          "group": "worktree@1"
        },
        {
          "command": "be-conductor.mergeWorktree",
          "when": "viewItem =~ /^worktree-(active|finalized)$/",
          "group": "worktree@2"
        },
        {
          "command": "be-conductor.deleteWorktree",
          "when": "viewItem =~ /^worktree-/",
          "group": "worktree@3"
        },
        {
          "command": "be-conductor.probeServer",
          "when": "viewItem =~ /^server-/",
          "group": "server@1"
        },
        {
          "command": "be-conductor.renameServer",
          "when": "viewItem =~ /^server-(remote|disabled)$/",
          "group": "server@2"
        },
        {
          "command": "be-conductor.toggleServer",
          "when": "viewItem =~ /^server-(remote|disabled)$/",
          "group": "server@3"
        },
        {
          "command": "be-conductor.removeServer",
          "when": "viewItem =~ /^server-(remote|disabled)$/",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "be-conductor",
      "properties": {
        "be-conductor.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:7777",
          "description": "URL of the be-conductor server"
        },
        "be-conductor.pollInterval": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "Polling interval for session/worktree refresh in milliseconds"
        }
      }
    }
  },
  "scripts": {
    "sync-version": "node -e \"const fs=require('fs');const t=fs.readFileSync('../../../pyproject.toml','utf8');const m=t.match(/^version\\s*=\\s*\\\"(.+?)\\\"/m);if(m){const p=JSON.parse(fs.readFileSync('package.json','utf8'));p.version=m[1];fs.writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n');console.log('Synced version to '+m[1])}\"",
    "prepackage": "npm run sync-version",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.32.0"
  }
}
